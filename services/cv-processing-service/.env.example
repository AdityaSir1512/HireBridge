# CV Processing Service - Environment Variables

# Service Configuration
PORT=3006
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://mongodb:27017/hirebridge

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_URL=amqp://rabbitmq:5672

# File Storage
FILE_STORAGE_PATH=/app/uploads/cv

# User Service URL (for profile updates)
USER_SERVICE_URL=http://user-service:3001

# AI Model Configuration
# Choose default AI model: 'openai', 'claude', or 'huggingface'
AI_PARSER_MODEL=openai

# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview
# Alternative models: gpt-4, gpt-3.5-turbo

# Anthropic Claude API Configuration (Optional)
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-opus-20240229
# Alternative models: claude-3-sonnet-20240229, claude-3-haiku-20240307

# Hugging Face API Configuration (Free alternative)
# Get your API key from: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# JWT Secret (if needed for authentication)
JWT_SECRET=your_jwt_secret_here

# Notes:
# - At least one AI API key (OpenAI, Anthropic, or Hugging Face) is required
# - OpenAI GPT-4 provides the best accuracy but is more expensive
# - Anthropic Claude is a great alternative with similar performance
# - Hugging Face is free but may have lower accuracy
# - The service will automatically fallback to available models if primary fails
